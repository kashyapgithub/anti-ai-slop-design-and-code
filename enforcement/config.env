# Configuration for the anti-ai-slop enforcement gates.
# Copy this whole `enforcement/` directory (and the matching workflow in
# .github/workflows/anti-slop-gates.yml) into your own project, then edit
# the values below to match your repo's actual layout. Nothing here is
# guessed — every value is something you should set deliberately once,
# the same way the guide asks you to write ARCHITECTURE.md deliberately.

# --- Architecture gate -------------------------------------------------
# Files that count as "the architecture is documented here". If a PR adds
# a brand-new top-level directory, one of these must also change in the
# same PR, or the gate fails. Space-separated, relative to repo root.
ARCHITECTURE_DOCS="ARCHITECTURE.md AGENTS.md CLAUDE.md docs/ARCHITECTURE.md"

# Top-level paths that are exempt from the "new folder needs a doc update"
# rule because they're not architectural (CI config, editor config, etc).
# Space-separated, matched as a prefix.
ARCHITECTURE_EXEMPT_PATHS=".github/ .vscode/ .git/ enforcement/"

# --- Integration-test gate ----------------------------------------------
# Extended-regex of path fragments that indicate a change crosses a real
# boundary (network call, DB write, queue publish, another module) and
# therefore needs an integration test, not just unit tests. Edit this to
# match your project's actual layout.
BOUNDARY_PATH_REGEX="(^|/)(api|routes|handlers|controllers|db|database|repository|repositories|queue|jobs|workers|services|clients|integrations)(/|$)"

# Extended-regex matching what counts as an integration test file.
# Defaults cover a few common conventions; keep whichever your stack uses.
INTEGRATION_TEST_REGEX="(integration|e2e)[-_.]?test|tests?/integration/|\\.integration\\.(test|spec)\\."

# Paths exempt from needing an integration test even if they match
# BOUNDARY_PATH_REGEX (e.g. pure type definitions, generated clients).
BOUNDARY_EXEMPT_REGEX="\\.d\\.ts$|/generated/|/__mocks__/"
